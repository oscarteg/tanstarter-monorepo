---
import Seo from "../components/Seo.astro";
import Footer from "../components/sections/Footer.astro";
import Navbar from "../components/sections/Navbar.astro";
import "../styles/global.css";

type Props = {
  /** Run through `site.seo.titleTemplate`. Omit on the home page. */
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
};

const { title, description, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo title={title} description={description} image={image} noindex={noindex} />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />

    {/* Registers the <el-*> custom elements used by the nav, FAQs and pricing tabs. */}
    <script>
      import "@tailwindplus/elements";
    </script>
  </body>
</html>
