---
import Seo from "../components/Seo.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import "../styles/global.css";

type Props = {
  /** Run through `site.seo.titleTemplate`. Omit on the home page. */
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
};

const { title, description, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* Honour the OS colour scheme up front; the Rams tokens theme via [data-theme]. */}
    <script is:inline>
      document.documentElement.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    </script>
    <Seo title={title} description={description} image={image} noindex={noindex} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
