---
import type { HTMLAttributes } from "astro/types";
import type { Faq } from "../../config/shared";
import Container from "../elements/Container.astro";
import Subheading from "../elements/Subheading.astro";
import Text from "../elements/Text.astro";
import MinusIcon from "../icons/MinusIcon.astro";
import PlusIcon from "../icons/PlusIcon.astro";

type Props = HTMLAttributes<"section"> & {
  headline: string;
  subheadline?: string;
  items: Faq[];
};

const { headline, subheadline, items, class: className, ...rest } = Astro.props;
---

<section class:list={["py-16", className]} {...rest}>
  <Container class="grid grid-cols-1 gap-x-2 gap-y-8 lg:grid-cols-2">
    <div class="flex flex-col gap-6">
      <Subheading>{headline}</Subheading>
      {
        subheadline && (
          <Text class="flex flex-col gap-4 text-pretty">
            <p>{subheadline}</p>
          </Text>
        )
      }
    </div>
    <div
      class="divide-y divide-olive-950/10 border-y border-olive-950/10 dark:divide-white/10 dark:border-white/10"
    >
      {
        items.map((faq) => (
          <div id={faq.id}>
            <button
              type="button"
              id={`${faq.id}-question`}
              command="--toggle"
              commandfor={`${faq.id}-answer`}
              class="flex w-full items-start justify-between gap-6 py-4 text-left text-base/7 text-olive-950 dark:text-white"
            >
              {faq.question}
              <PlusIcon class="h-lh in-aria-expanded:hidden" />
              <MinusIcon class="h-lh not-in-aria-expanded:hidden" />
            </button>
            <el-disclosure
              id={`${faq.id}-answer`}
              hidden
              class="-mt-2 flex flex-col gap-2 pr-12 pb-4 text-sm/7 text-olive-700 dark:text-olive-400"
            >
              {faq.answer}
            </el-disclosure>
          </div>
        ))
      }
    </div>
  </Container>
</section>
