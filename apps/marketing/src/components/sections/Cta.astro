---
import { home } from "../../config/home";

const { cta } = home;
---

<section class="rams-wrap cta">
  <div class="cta-inner">
    <h2 class="cta-title">{cta.headline}</h2>
    <p class="cta-lead">{cta.subheadline}</p>
    <div class="cta-actions">
      <a href={cta.primaryCta.href} class="btn-solid">{cta.primaryCta.label}</a>
      <a href={cta.secondaryCta.href} class="om-link-heading btn-plain">{cta.secondaryCta.label} →</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: 130px 120px;
  }

  .cta-inner {
    border-top: 1px solid var(--border-hairline);
    padding-top: 72px;
  }

  .cta-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-heading);
    margin: 0;
    max-width: 20ch;
    text-wrap: balance;
  }

  .cta-lead {
    font: var(--type-body-lg);
    color: var(--text-muted);
    margin: 20px 0 0 0;
    max-width: 60ch;
    text-wrap: pretty;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-top: 34px;
  }

  .btn-solid {
    font: var(--type-mono);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--on-ink);
    padding: 14px 24px;
    border-radius: 2px;
  }

  .btn-solid:hover {
    color: var(--on-ink);
    background: var(--accent-press);
  }

  .btn-plain {
    font: var(--type-mono);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-heading);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  @media (max-width: 720px) {
    .cta-actions {
      flex-wrap: wrap;
      gap: 16px;
    }
  }
</style>
