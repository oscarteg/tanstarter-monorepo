---
import type { HTMLAttributes } from "astro/types";
import type { SocialPlatform } from "../../config/site";
import { site } from "../../config/site";
import Container from "../elements/Container.astro";
import ArrowNarrowRightIcon from "../icons/ArrowNarrowRightIcon.astro";
import GitHubIcon from "../icons/social/GitHubIcon.astro";
import XIcon from "../icons/social/XIcon.astro";
import YouTubeIcon from "../icons/social/YouTubeIcon.astro";

type Props = HTMLAttributes<"footer">;

const { class: className, ...rest } = Astro.props;

const socialIcons: Record<SocialPlatform, typeof XIcon> = {
  x: XIcon,
  github: GitHubIcon,
  youtube: YouTubeIcon,
};
---

<footer class:list={["pt-16", className]} {...rest}>
  <div class="bg-olive-950/2.5 py-16 text-olive-950 dark:bg-white/5 dark:text-white">
    <Container class="flex flex-col gap-16">
      <div class="grid grid-cols-1 gap-x-6 gap-y-16 text-sm/7 lg:grid-cols-2">
        <form class="flex max-w-sm flex-col gap-2" action={site.newsletter.action}>
          <p>{site.newsletter.headline}</p>
          <div class="flex flex-col gap-4 text-olive-700 dark:text-olive-400">
            <p>{site.newsletter.subheadline}</p>
          </div>
          <div
            class="flex items-center border-b border-olive-950/20 py-2 has-[input:focus]:border-olive-950 dark:border-white/20 dark:has-[input:focus]:border-white"
          >
            <input
              type="email"
              placeholder="Email"
              aria-label="Email"
              class="flex-1 text-olive-950 focus:outline-hidden dark:text-white"
            />
            <button
              type="submit"
              aria-label="Subscribe"
              class="relative inline-flex size-7 items-center justify-center rounded-full after:absolute after:-inset-2 hover:bg-olive-950/10 dark:hover:bg-white/10 after:pointer-fine:hidden"
            >
              <ArrowNarrowRightIcon />
            </button>
          </div>
        </form>

        <nav
          class="grid grid-cols-2 gap-6 sm:has-[>:last-child:nth-child(3)]:grid-cols-3 sm:has-[>:nth-child(5)]:grid-cols-3 md:has-[>:last-child:nth-child(4)]:grid-cols-4 lg:max-xl:has-[>:last-child:nth-child(4)]:grid-cols-2"
        >
          {
            site.footer.categories.map((category) => (
              <div>
                <h3>{category.title}</h3>
                <ul role="list" class="mt-2 flex flex-col gap-2">
                  {category.links.map((link) => (
                    <li class="text-olive-700 dark:text-olive-400">
                      <a href={link.href}>{link.label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </div>
      <div class="flex items-center justify-between gap-10 text-sm/7">
        <div class="text-olive-600 dark:text-olive-500">{site.footer.fineprint}</div>
        {
          site.social.length > 0 && (
            <div class="flex items-center gap-4 sm:gap-10">
              {site.social.map((link) => {
                const Icon = socialIcons[link.platform];
                return (
                  <a
                    href={link.href}
                    target="_blank"
                    aria-label={link.name}
                    class="text-olive-950 *:size-6 dark:text-white"
                  >
                    <Icon />
                  </a>
                );
              })}
            </div>
          )
        }
      </div>
    </Container>
  </div>
</footer>
