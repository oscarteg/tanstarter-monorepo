---
import { site } from "../../config/site";

const { name, footer, social } = site;
const fineprint = footer.fineprint.replace("%s", name);
---

<footer class="site-footer">
  <div class="rams-wrap footer-grid">
    <div class="newsletter">
      <div class="newsletter-title">{footer.newsletter.headline}</div>
      <p class="newsletter-body">{footer.newsletter.body}</p>
      <form class="newsletter-form" onsubmit="return false">
        <input
          type="email"
          class="newsletter-input"
          placeholder={footer.newsletter.placeholder}
          aria-label={footer.newsletter.placeholder}
        />
        <button type="submit" class="newsletter-submit" aria-label="Subscribe">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
    </div>

    {
      footer.columns.map((column) => (
        <div>
          <div class="col-title">{column.title}</div>
          <div class="col-links">
            {column.links.map((link) => (
              <a href={link.href} class="om-link-heading foot-link">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="footer-bar">
    <div class="rams-wrap footer-bar-inner">
      <span class="copyright">{fineprint}</span>
      <div class="social">
        {
          social.map((link) => (
            <a href={link.href} class="om-link-heading social-link" aria-label={link.name}>
              {link.platform === "x" && (
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.9 1.2h3.7l-8 9.1L24 22.8h-7.4l-5.8-7.6-6.6 7.6H.5l8.6-9.8L0 1.2h7.6l5.2 6.9 6.1-6.9Zm-1.3 19.4h2L6.5 3.3H4.3L17.6 20.6Z" />
                </svg>
              )}
              {link.platform === "github" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .5C5.4.5 0 5.9 0 12.6c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.6C24 5.9 18.6.5 12 .5Z" />
                </svg>
              )}
              {link.platform === "youtube" && (
                <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z" />
                </svg>
              )}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-hairline);
    background: var(--surface-card);
  }

  .footer-grid {
    padding-block: 64px 40px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 40px;
  }

  .newsletter-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 16px;
    color: var(--text-heading);
  }

  .newsletter-body {
    font: var(--text-small);
    color: var(--text-muted);
    margin: 12px 0 18px 0;
    max-width: 34ch;
  }

  .newsletter-form {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-strong);
    background: var(--surface-page);
    max-width: 300px;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: none;
    padding: 11px 13px;
    font: var(--text-mono);
    color: var(--text-heading);
  }

  .newsletter-submit {
    border: none;
    background: var(--ink);
    color: var(--on-ink);
    cursor: pointer;
    padding: 11px 15px;
    display: flex;
    align-items: center;
  }

  .col-title {
    font: var(--text-kicker);
    letter-spacing: var(--track-kicker);
    text-transform: uppercase;
    color: var(--text-meta);
    margin-bottom: 16px;
  }

  .col-links {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .foot-link {
    font: var(--text-small);
    color: var(--text-body);
  }

  .footer-bar {
    border-top: 1px solid var(--border-hairline);
  }

  .footer-bar-inner {
    padding-block: 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .copyright {
    font: var(--text-mono-sm);
    letter-spacing: 0.04em;
    color: var(--text-meta);
  }

  .social {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .social-link {
    display: flex;
    color: var(--text-muted);
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 520px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
