---
import type { PricingTier } from "../../config/pricing";
import ButtonLink from "../elements/ButtonLink.astro";
import SoftButtonLink from "../elements/SoftButtonLink.astro";
import CheckmarkIcon from "../icons/CheckmarkIcon.astro";

/** One pricing card. Shared by the home pricing section and the pricing hero. */
type Props = {
  tier: PricingTier;
  price: string;
  period?: string;
};

const { tier, price, period } = Astro.props;

const Cta = tier.cta.variant === "solid" ? ButtonLink : SoftButtonLink;
---

<div class="flex flex-col justify-between gap-6 rounded-xl bg-olive-950/2.5 p-6 sm:items-start dark:bg-white/5">
  <div class="self-stretch">
    <div class="flex items-center justify-between">
      {
        tier.badge && (
          <div class="order-last inline-flex rounded-full bg-olive-950/10 px-2 text-xs/6 font-medium text-olive-950 dark:bg-white/10 dark:text-white">
            {tier.badge}
          </div>
        )
      }

      <h3 class="text-2xl/8 tracking-tight text-olive-950 dark:text-white">{tier.name}</h3>
    </div>
    <p class="mt-1 inline-flex gap-1 text-base/7">
      <span class="text-olive-950 dark:text-white">{price}</span>
      {period && <span class="text-olive-500 dark:text-olive-500">{period}</span>}
    </p>
    <div class="mt-4 flex flex-col gap-4 text-sm/6 text-olive-700 dark:text-olive-400">
      <p>{tier.blurb}</p>
    </div>
    <ul class="mt-4 space-y-2 text-sm/6 text-olive-700 dark:text-olive-400">
      {
        tier.features.map((feature) => (
          <li class="flex gap-4">
            <CheckmarkIcon class="h-lh shrink-0 stroke-olive-950 dark:stroke-white" />
            <p>{feature}</p>
          </li>
        ))
      }
    </ul>
  </div>
  <Cta href={tier.cta.href} size="lg">{tier.cta.label}</Cta>
</div>
