---
import type { HTMLAttributes } from "astro/types";
import Container from "../elements/Container.astro";
import Heading from "../elements/Heading.astro";
import Text from "../elements/Text.astro";

type Props = HTMLAttributes<"section"> & {
  headline: string;
  subheadline: string;
};

const { headline, subheadline, class: className, ...rest } = Astro.props;
---

<section class:list={["py-16", className]} {...rest}>
  <Container class="flex flex-col items-center gap-6">
    <slot name="eyebrow" />
    <Heading class="max-w-5xl text-center">{headline}</Heading>
    <Text size="lg" class="flex max-w-xl flex-col gap-4 text-center">
      <p>{subheadline}</p>
    </Text>
    <slot name="cta" />
  </Container>
</section>
