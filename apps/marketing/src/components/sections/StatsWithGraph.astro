---
import type { StatsSection } from "../../config/shared";
import Section from "../elements/Section.astro";

type Props = StatsSection & {
  id?: string;
};

const { id, eyebrow, headline, subheadline, items } = Astro.props;

// Derived from the section id so it stays unique per page and stable per build.
const pathId = id ? `${id}-graph` : "stats-graph";

const curve =
  "M 0 400 L 0 383 C 396 362.7936732276819, 804 264.31672304481856, 1200 60 L 1200 60 L 1200 400 Z";

const gridLines = Array.from({ length: 14 }, (_, index) => {
  if (index === 0) return 0.5;
  if (index === 13) return 1199.5;
  return (1200 / 13) * index;
});
---

<Section id={id} eyebrow={eyebrow} headline={headline} subheadline={subheadline}>
  <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
    <div class="col-span-2 grid grid-cols-2 gap-x-2 gap-y-10 sm:auto-cols-fr sm:grid-flow-col-dense">
      {
        items.map((item) => (
          <div class="border-l border-olive-950/20 pl-6 dark:border-white/20">
            <div class="text-2xl/10 tracking-tight text-olive-950 dark:text-white">{item.stat}</div>
            <p class="mt-2 text-sm/7 text-olive-700 dark:text-olive-400">{item.text}</p>
          </div>
        ))
      }
    </div>
  </div>
  <div class="pointer-events-none relative h-48 sm:h-64 lg:h-36">
    <div
      class="absolute bottom-0 left-1/2 w-[150vw] max-w-[calc(var(--container-7xl)-(--spacing(10)*2))] -translate-x-1/2"
    >
      <svg
        class="h-100 w-full fill-olive-950/2.5 stroke-olive-950/40 dark:fill-white/2.5 dark:stroke-white/40"
        viewBox="0 0 1200 400"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <defs>
          <clipPath id={pathId}>
            <path d={curve}></path>
          </clipPath>
        </defs>
        <path d={curve} stroke="none"></path>
        <g stroke-width="1" stroke-dasharray="4 3" clip-path={`url(#${pathId})`}>
          {
            gridLines.map((x) => (
              <line x1={x} y1="400" x2={x} y2="0" vector-effect="non-scaling-stroke" />
            ))
          }
        </g>
        <path
          d="M 0 383 C 396 362.7936732276819, 804 264.31672304481856, 1200 60"
          fill="none"
          stroke-width="1"
          vector-effect="non-scaling-stroke"></path>
      </svg>
    </div>
  </div>
</Section>
