---
import type { FeatureItem } from "../../config/home";
import Link from "../elements/Link.astro";
import Screenshot from "../elements/Screenshot.astro";
import Section from "../elements/Section.astro";
import ArrowNarrowRightIcon from "../icons/ArrowNarrowRightIcon.astro";

type Props = {
  id?: string;
  eyebrow: string;
  headline: string;
  subheadline: string;
  items: FeatureItem[];
};

const { id, eyebrow, headline, subheadline, items } = Astro.props;

// Art direction: each breakpoint gets a differently-cropped screenshot so the
// demo stays legible as the card changes shape.
const crops = [
  { width: 1000, height: 800, visibility: "sm:hidden" },
  { width: 1800, height: 660, visibility: "max-sm:hidden lg:hidden" },
  { width: 1300, height: 1300, visibility: "max-lg:hidden xl:hidden" },
  { width: 1800, height: 1250, visibility: "max-xl:hidden" },
];
---

<Section id={id} eyebrow={eyebrow} headline={headline} subheadline={subheadline}>
  <div class="grid grid-cols-1 gap-2 lg:grid-cols-2">
    {
      items.map((feature) => {
        // The crop is anchored to the edge opposite the screenshot's placement.
        const axis = feature.placement.endsWith("right") ? "left" : "right";

        return (
          <div class="rounded-lg bg-olive-950/2.5 p-2 dark:bg-white/5">
            <div class="relative overflow-hidden rounded-sm dark:after:absolute dark:after:inset-0 dark:after:rounded-sm dark:after:outline-1 dark:after:-outline-offset-1 dark:after:outline-white/10">
              <Screenshot wallpaper={feature.wallpaper} placement={feature.placement}>
                {crops.map((crop) => {
                  const src = `${feature.screenshot}?${axis}=${crop.width}&top=${crop.height}`;
                  return (
                    <>
                      <img
                        src={src}
                        alt=""
                        class:list={["bg-white/75", crop.visibility, "dark:hidden"]}
                        width={crop.width}
                        height={crop.height}
                      />
                      <img
                        src={`${src}&color=olive`}
                        alt=""
                        class:list={["bg-black/75 not-dark:hidden", crop.visibility]}
                        width={crop.width}
                        height={crop.height}
                      />
                    </>
                  );
                })}
              </Screenshot>
            </div>
            <div class="flex flex-col gap-4 p-6 sm:p-10 lg:p-6">
              <div>
                <h3 class="text-base/8 font-medium text-olive-950 dark:text-white">{feature.headline}</h3>
                <div class="mt-2 flex flex-col gap-4 text-sm/7 text-olive-700 dark:text-olive-400">
                  <p>{feature.subheadline}</p>
                </div>
              </div>
              <Link href={feature.cta.href}>
                {feature.cta.label} <ArrowNarrowRightIcon />
              </Link>
            </div>
          </div>
        );
      })
    }
  </div>
</Section>
