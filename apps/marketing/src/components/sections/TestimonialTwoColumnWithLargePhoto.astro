---
import type { HTMLAttributes } from "astro/types";
import type { Testimonial } from "../../config/shared";
import Container from "../elements/Container.astro";

type Props = HTMLAttributes<"section"> & {
  testimonial: Testimonial;
};

const { testimonial, class: className, ...rest } = Astro.props;
---

<section class:list={["py-16", className]} {...rest}>
  <Container>
    <figure class="grid grid-cols-1 gap-x-2 rounded-xl bg-olive-950/2.5 p-2 lg:grid-cols-2 dark:bg-white/5">
      <div class="flex flex-col items-start justify-between gap-10 p-6 text-olive-950 sm:p-10 dark:text-white">
        <blockquote
          class="relative flex flex-col gap-4 text-2xl/9 text-pretty *:first:before:absolute *:first:before:inline *:first:before:-translate-x-full *:first:before:content-['“'] *:last:after:inline *:last:after:content-['”']"
        >
          <p>{testimonial.quote}</p>
        </blockquote>
        <figcaption class="text-sm/7">
          <p class="font-semibold">{testimonial.name}</p>
          <p class="text-olive-700 dark:text-olive-400">{testimonial.byline}</p>
        </figcaption>
      </div>
      <div
        class="flex overflow-hidden rounded-sm outline -outline-offset-1 outline-black/5 *:object-cover dark:outline-white/5"
      >
        <img
          src={testimonial.avatar}
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={1400}
          height={1000}
        />
      </div>
    </figure>
  </Container>
</section>
