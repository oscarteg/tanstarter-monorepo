---
import { getEntry, render } from "astro:content";
import ButtonLink from "../components/elements/ButtonLink.astro";
import Document from "../components/elements/Document.astro";
import Main from "../components/elements/Main.astro";
import PlainButtonLink from "../components/elements/PlainButtonLink.astro";
import Section from "../components/elements/Section.astro";
import ChevronIcon from "../components/icons/ChevronIcon.astro";
import CallToActionSimple from "../components/sections/CallToActionSimple.astro";
import HeroLeftAlignedWithPhoto from "../components/sections/HeroLeftAlignedWithPhoto.astro";
import StatsWithGraph from "../components/sections/StatsWithGraph.astro";
import TeamFourColumnGrid from "../components/sections/TeamFourColumnGrid.astro";
import TestimonialTwoColumnWithLargePhoto from "../components/sections/TestimonialTwoColumnWithLargePhoto.astro";
import { about } from "../config/about";
import { featuredTestimonial, statsSection } from "../config/shared";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "about");
if (!entry) throw new Error("Missing src/content/pages/about.mdx");

const { Content } = await render(entry);
const { title, subheadline, photo, proseHeadline, description } = entry.data;
if (!photo) throw new Error("about.mdx needs a `photo` in its frontmatter");
---

<Layout title="About" description={description}>
  <Main>
    <HeroLeftAlignedWithPhoto id="hero" headline={title} subheadline={subheadline ?? ""} photo={photo} />

    <Section id="story" headline={proseHeadline}>
      <Document class="max-w-2xl">
        <Content />
      </Document>
    </Section>

    <StatsWithGraph
      id="stats"
      eyebrow={statsSection.eyebrow}
      headline={statsSection.headline}
      subheadline={statsSection.subheadline}
      items={statsSection.items}
    />

    <TestimonialTwoColumnWithLargePhoto id="testimonial" testimonial={featuredTestimonial} />

    <TeamFourColumnGrid
      id="team"
      headline={about.team.headline}
      subheadline={about.team.subheadline}
      members={about.team.members}
    />

    <CallToActionSimple id="call-to-action" headline={about.cta.headline} subheadline={about.cta.subheadline}>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href={about.cta.primaryCta.href} size="lg">{about.cta.primaryCta.label}</ButtonLink>

        <PlainButtonLink href={about.cta.secondaryCta.href} size="lg">
          {about.cta.secondaryCta.label} <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimple>
  </Main>
</Layout>
