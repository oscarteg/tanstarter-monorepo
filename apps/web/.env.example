VITE_BASE_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/tanstarter"
# You can also use Docker Compose to set up a local PostgreSQL database:
# docker-compose up -d

# vp run auth:secret
BETTER_AUTH_SECRET=

# SSO via Authelia (self-hosted OIDC), optional.
# Leave blank to use email + password only — the provider is only registered,
# and the SSO button only rendered, when these are set.
AUTHELIA_ISSUER_URL=
AUTHELIA_CLIENT_ID=
AUTHELIA_CLIENT_SECRET=
# Set to "true" to show the Authelia button on /login and /signup.
VITE_AUTHELIA_ENABLED=

# Optional: outbound email (Resend). Leave the key blank and every message —
# including password-reset links — is printed to the console instead of sent,
# which is all local development needs.
# EMAIL_FROM must be a verified sender, e.g. "Acme <no-reply@acme.com>".
RESEND_API_KEY=
EMAIL_FROM=

# Optional: error monitoring (Sentry). Leave blank to disable.
VITE_SENTRY_DSN=

# Optional: product analytics (PostHog). Leave the key blank to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# NOTE:
# In Authelia's OIDC client config, set the redirect URI to
# http://localhost:3000/api/auth/callback/authelia